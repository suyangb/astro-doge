{
	"name": "astro-doge",
	"type": "module",
	"version": "1.0.0",
	"description": "一个简洁轻量的 Astro 博客主题",
	"scripts": {
		"dev": "astro dev",
		"dev:network": "astro dev --host",
		"build": "astro check && astro build",
		"preview": "astro preview",
		"preview:network": "astro preview --host",
		"astro": "astro",
		"format": "prettier . --write",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix",
		"new:blog": "bun run scripts/new-blog.ts",
		"new:thought": "bun run scripts/new-thought.ts",
		"new": "bun run scripts/new-blog.ts",
		"t": "bun run scripts/new-thought.ts"
	},
	"dependencies": {
		"@astrojs/check": "^0.9.6",
		"@astrojs/mdx": "4.3.13",
		"@astrojs/rss": "4.0.15",
		"@astrojs/sitemap": "3.7.0",
		"@fontsource/inter": "^5.2.8",
		"@fontsource/lora": "^5.2.8",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.1.17",
		"@typescript-eslint/eslint-plugin": "^8.48.1",
		"@typescript-eslint/parser": "^8.48.1",
		"astro": "5.17.3",
		"astro-expressive-code": "^0.41.3",
		"clsx": "^2.1.1",
		"eslint": "^9.39.1",
		"eslint-plugin-astro": "^1.5.0",
		"eslint-plugin-jsx-a11y": "^6.10.2",
		"rehype-slug": "^6.0.0",
		"tailwind-merge": "^3.4.0",
		"tailwindcss": "^4.1.17",
		"typescript": "^5.9.3",
		"unist-util-visit": "^5.0.0"
	},
	"devDependencies": {
		"eslint-config-prettier": "^10.1.8",
		"prettier": "^3.7.4",
		"prettier-plugin-astro": "^0.14.1",
		"prettier-plugin-tailwindcss": "^0.7.2"
	}
}

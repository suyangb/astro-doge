---
interface Props {
  date: Date
}

const { date } = Astro.props
---

<time datetime={date.toISOString()}>
  {
    date
      .toLocaleDateString('zh-CN', {
        year: 'numeric',
        month: 'long',
        day: 'numeric',
      })
      .replace('年', ' 年 ')
      .replace('月', ' 月 ')
      .replace('日', ' 日')
  }
</time>

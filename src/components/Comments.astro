---
interface Props {
	slug: string;
	title: string;
}
const { slug, title } = Astro.props;
---

<section class="comments-section">
  <div id="twikoo"></div>
</section>

<script is:inline>
// 关键：用 is:inline 避免 Astro 编译问题
const TWIKOO_ENV_ID = "你的-env-id";
const TWIKOO_REGION = "ap-shanghai";

function initTwikoo() {
  const el = document.getElementById('twikoo');
  if (!el || window.twikooInited) return;
  window.twikooInited = true;

  // 动态加载
  const script = document.createElement('script');
  script.src = "https://cdn.staticfile.org/twikoo/1.6.26/twikoo.all.min.js";
  script.onload = () => {
    window.twikoo.init({
      envId: TWIKOO_ENV_ID,
      region: TWIKOO_REGION,
      el: '#twikoo',
      path: window.location.pathname, // 更稳
      title: document.title,
      enableQQ: false,
    });
  };
  document.head.appendChild(script);
}

// 兼容 Astro 路由切换
document.addEventListener('DOMContentLoaded', initTwikoo);
document.addEventListener('astro:after-swap', initTwikoo);
</script>

<style>
.comments-section {
  margin-top: 2rem;
}
#twikoo {
  width: 100%;
}
</style>

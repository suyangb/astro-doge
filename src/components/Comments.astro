
<div class="mt-12">
  <h2 class="text-xl font-semibold mb-6">评论</h2>
  <div id="waline" class="rounded-lg border border-gray-200 dark:border-gray-800 p-4 bg-white dark:bg-gray-900"></div>
</div>

<script>
  import { init } from '@waline/client';
  import '@waline/client/dist/waline.css';

  // 等待 DOM 加载完成
  document.addEventListener('DOMContentLoaded', () => {
    init({
      el: '#waline',
      // 替换成你自己的 Waline 服务端地址
      serverURL: 'https://pinglun.wsyblog.cn',

      // 文章唯一标识，使用路径即可
      path: window.location.pathname,

      // 表单字段
      meta: ['nick', 'mail', 'link'],
      requiredMeta: ['nick'],

      // 语言
      lang: 'zh-CN',

      // 关键：适配 astro-doge 的暗色模式
      dark: 'html.dark',

      // 可选：表情包、评论计数等
      emoji: false,
      reaction: false,
    });
  });
</script>

<style>
  /* 轻微对齐主题样式 */
  #waline {
    --waline-font-size: 0.9rem;
    --waline-space: 1rem;
  }
</style>

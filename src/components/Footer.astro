---
import Container from "@components/Container.astro";
import { SITE } from "@consts";
---

<footer class="animate border-stone-200 dark:border-stone-800">
  <Container>
    <div class="py-8">
      <hr class="my-6 border-stone-200 dark:border-stone-800" />
      <div class="flex flex-col gap-8 sm:flex-row sm:justify-between">
        <div class="space-y-3">
          <div class="font-semibold text-stone-900 dark:text-stone-100">
            {SITE.NAME}
          </div>
          <p class="max-w-xs text-sm text-stone-600 dark:text-stone-400">
            {SITE.DESCRIPTION}
          </p>
        </div>

        <div class="flex gap-12">
          <div class="space-y-3">
            <div class="text-xs font-semibold tracking-wider text-stone-500 uppercase dark:text-stone-400">
              导航
            </div>
            <ul class="space-y-2 text-sm">
              <li>
                <a href="/posts" class="text-stone-600 transition-colors hover:text-stone-900 dark:text-stone-400 dark:hover:text-stone-100">
                  文章
                </a>
              </li>
              <li>
                <a href="/thoughts" class="text-stone-600 transition-colors hover:text-stone-900 dark:text-stone-400 dark:hover:text-stone-100">
                  碎碎念
                </a>
              </li>
              <li>
                <a href="/friends" class="text-stone-600 transition-colors hover:text-stone-900 dark:text-stone-400 dark:hover:text-stone-100">
                  友链
                </a>
              </li>
            </ul>
          </div>

          <div class="space-y-3">
            <div class="text-xs font-semibold tracking-wider text-stone-500 uppercase dark:text-stone-400">
              更多
            </div>
            <ul class="space-y-2 text-sm">
              <li>
                <a href="/about" class="text-stone-600 transition-colors hover:text-stone-900 dark:text-stone-400 dark:hover:text-stone-100">
                  关于
                </a>
              </li>
              <li>
                <a href="/rss.xml" target="_blank" class="inline-flex items-center gap-1 text-stone-600 transition-colors hover:text-stone-900 dark:text-stone-400 dark:hover:text-stone-100">
                  RSS
                  <svg class="h-3 w-3 opacity-60" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M7 17L17 7M17 7H7M17 7V17"></path>
                  </svg>
                </a>
              </li>
              <li>
                <a href="https://github.com/username" target="_blank" class="inline-flex items-center gap-1 text-stone-600 transition-colors hover:text-stone-900 dark:text-stone-400 dark:hover:text-stone-100">
                  GitHub
                  <svg class="h-3 w-3 opacity-60" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M7 17L17 7M17 7H7M17 7V17"></path>
                  </svg>
                </a>
              </li>
            </ul>
          </div>
        </div>
      </div>

      <hr class="my-6 border-stone-200 dark:border-stone-800" />

      <!-- 官方标准备案排版 -->
      <div class="flex flex-col items-center justify-center gap-2 text-sm text-stone-500 sm:flex-row sm:justify-between dark:text-stone-400">
        <div class="flex flex-wrap items-center justify-center gap-x-3 gap-y-1">
          <span>&copy; 2024-{new Date().getFullYear()} {SITE.NAME}</span>
          
          <!-- ICP 备案 -->
          <a href="https://beian.miit.gov.cn/" target="_blank" rel="noopener noreferrer" class="hover:text-stone-800 dark:hover:text-stone-300">
            皖ICP备2024049551号-2
          </a>
          
          <!-- 公安备案 官方图标 + 标准格式 -->
          <a 
            href="https://beian.gov.cn/?id=34162202003345" 
            target="_blank" 
            rel="noopener noreferrer"
            class="inline-flex items-center gap-1 hover:text-stone-800 dark:hover:text-stone-300"
          >
            <img 
              src="https://www.beian.gov.cn/img/ga.png" 
              alt="网安备案" 
              class="h-4 w-auto"
            />
            皖公网安备34162202003345号
          </a>
        </div>

        <div class="text-xs text-stone-400 dark:text-stone-500">
          Built with Astro Doge
        </div>
      </div>
    </div>
  </Container>
</footer>

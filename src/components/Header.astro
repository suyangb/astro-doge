---
import Container from "@components/Container.astro";
import Link from "@components/Link.astro";
import ThemeToggle from "@components/ThemeToggle.astro";
import { SITE } from "@consts";

const navItems = [
	{ href: "/posts", label: "文章" },
	{ href: "/thoughts", label: "碎碎念" },
];

const desktopItems = [
	{ href: "/friends", label: "友链" },
	{ href: "/messages", label: "留言板" },
	{ href: "/friends", label: "友链" },
];

const mobileMoreItems = [
	{ href: "/about", label: "关于" },
	{ href: "/messages", label: "留言板" },
];
---

<header id="main-header">
  <Container
    class="border-b border-stone-200/50 px-3 py-2.5 sm:px-5 sm:py-3 dark:border-stone-800"
  >
    <div class="flex items-center justify-between">
      <Link href="/" underline={false} class="shrink-0">
        <div class="text-sm font-semibold sm:text-base">
          {SITE.NAME}
        </div>
      </Link>
      <nav class="flex items-center gap-2 sm:gap-4">
        {
          navItems.map((item) => (
            <Link
              href={item.href}
              underline={false}
              class="nav-link text-xs sm:text-sm"
            >
              {item.label}
            </Link>
          ))
        }

        {/* 移动端显示关于 */}
        <Link
          href="/about"
          underline={false}
          class="nav-link text-xs sm:hidden!"
        >
          关于
        </Link>

        {/* 桌面端显示项目、友链、关于 */}
        {
          desktopItems.map((item) => (
            <Link
              href={item.href}
              underline={false}
              class="nav-link hidden! text-sm sm:inline!"
            >
              {item.label}
            </Link>
          ))
        }

        {/* 移动端更多菜单 */}
        <div id="more-menu" class="relative sm:hidden">
          <button
            id="more-btn"
            class="flex h-7 w-7 items-center justify-center rounded-md text-stone-500 transition-colors duration-200 hover:bg-stone-100 hover:text-stone-700 dark:text-stone-400 dark:hover:bg-stone-800 dark:hover:text-stone-200"
            aria-label="更多导航"
            aria-expanded="false"
          >
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor">
              <circle cx="12" cy="5" r="2"></circle>
              <circle cx="12" cy="12" r="2"></circle>
              <circle cx="12" cy="19" r="2"></circle>
            </svg>
          </button>
          <div
            id="more-dropdown"
            class="absolute top-full right-0 z-50 mt-2 hidden min-w-[80px] rounded-lg border border-stone-200 bg-white py-1 shadow-lg dark:border-stone-700 dark:bg-stone-900"
          >
            {
              mobileMoreItems.map((item) => (
                <a
                  href={item.href}
                  class="dropdown-item block px-4 py-2 text-sm whitespace-nowrap text-stone-600 transition-colors hover:bg-stone-100 hover:text-stone-900 dark:text-stone-400 dark:hover:bg-stone-800 dark:hover:text-stone-100"
                >
                  {item.label}
                </a>
              ))
            }
          </div>
        </div>

        {/* 分隔线 */}
        <div class="h-4 w-px bg-stone-200 dark:bg-stone-700"></div>

        {/* 搜索按钮 */}
        <button
          id="search-toggle"
          class="flex h-7 w-7 items-center justify-center rounded-md text-stone-500 transition-colors duration-200 hover:bg-stone-100 hover:text-stone-700 sm:h-8 sm:w-8 dark:text-stone-400 dark:hover:bg-stone-800 dark:hover:text-stone-200"
          aria-label="搜索"
          title="搜索 (Ctrl+K)"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-4 w-4"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <circle cx="11" cy="11" r="8"></circle>
            <path d="m21 21-4.3-4.3"></path>
          </svg>
        </button>
        <ThemeToggle />
      </nav>
    </div>
  </Container>
</header>

<!-- 搜索模态框 -->
<div
  id="search-modal"
  class="fixed inset-0 z-[100] hidden items-center justify-center bg-black/50 p-4 backdrop-blur-sm"
  role="dialog"
  aria-modal="true"
  aria-label="搜索"
>
  <div
    class="search-container w-full max-w-xl translate-y-4 scale-95 transform rounded-xl bg-white opacity-0 shadow-2xl transition-all duration-200 dark:bg-stone-900"
  >
    <!-- 搜索输入框 -->
    <div
      class="flex items-center border-b border-stone-200 px-4 dark:border-stone-700"
    >
      <svg
        class="mr-3 h-5 w-5 shrink-0 text-stone-400"
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <circle cx="11" cy="11" r="8"></circle>
        <path d="m21 21-4.3-4.3"></path>
      </svg>
      <input
        id="search-input"
        type="text"
        placeholder="搜索文章、碎碎念..."
        class="flex-1 bg-transparent py-4 text-sm text-stone-900 placeholder-stone-400 outline-none dark:text-stone-100 dark:placeholder-stone-500"
        autocomplete="off"
      />
      <kbd
        class="hidden rounded bg-stone-100 px-2 py-1 text-xs text-stone-500 sm:inline dark:bg-stone-800 dark:text-stone-400"
        >ESC</kbd
      >
    </div>

    <!-- 搜索结果 -->
    <div id="search-results" class="max-h-80 overflow-y-auto p-2">
      <div
        class="search-hint px-3 py-8 text-center text-sm text-stone-500 dark:text-stone-400"
      >
        输入关键词开始搜索
      </div>
    </div>

    <!-- 搜索提示 -->
    <div
      class="hidden items-center justify-between border-t border-stone-200 px-4 py-2 text-xs text-stone-400 sm:flex dark:border-stone-700 dark:text-stone-500"
    >
      <div class="flex items-center gap-3">
        <span class="flex items-center gap-1">
          <kbd class="rounded bg-stone-100 px-1.5 py-0.5 dark:bg-stone-800"
            >↑</kbd
          >
          <kbd class="rounded bg-stone-100 px-1.5 py-0.5 dark:bg-stone-800"
            >↓</kbd
          >
          导航
        </span>
        <span class="flex items-center gap-1">
          <kbd class="rounded bg-stone-100 px-1.5 py-0.5 dark:bg-stone-800"
            >↵</kbd
          >
          打开
        </span>
      </div>
      <span>本地搜索</span>
    </div>
  </div>
</div>

<script>
  interface SearchItem {
    title: string
    description?: string
    url: string
    type: 'post' | 'thought'
    date: string
    content?: string
    tags?: string[]
  }

  let searchData: SearchItem[] = []
  let selectedIndex = -1
  const HISTORY_KEY = 'search_history'
  const MAX_HISTORY = 5

  // 获取搜索历史
  function getSearchHistory(): string[] {
    try {
      const history = localStorage.getItem(HISTORY_KEY)
      return history ? JSON.parse(history) : []
    } catch {
      return []
    }
  }

  // 保存搜索历史
  function saveSearchHistory(query: string) {
    if (!query || query.length < 2) return
    try {
      let history = getSearchHistory()
      // 移除重复项
      history = history.filter((item) => item !== query)
      // 添加到开头
      history.unshift(query)
      // 限制数量
      history = history.slice(0, MAX_HISTORY)
      localStorage.setItem(HISTORY_KEY, JSON.stringify(history))
    } catch {
      // 忽略存储错误
    }
  }

  // 清除搜索历史
  function clearSearchHistory() {
    try {
      localStorage.removeItem(HISTORY_KEY)
    } catch {
      // 忽略错误
    }
  }

  async function loadSearchData() {
    if (searchData.length > 0) return

    try {
      const response = await fetch('/api/search.json')
      searchData = await response.json()
    } catch (e) {
      console.error('Failed to load search data:', e)
    }
  }

  function highlightText(text: string, query: string): string {
    if (!query) return text
    const regex = new RegExp(
      `(${query.replace(/[.*+?^${}()|[\]\\]/g, '\\$&')})`,
      'gi',
    )
    return text.replace(regex, '<mark class="search-highlight">$1</mark>')
  }

  function search(query: string): SearchItem[] {
    if (!query || query.length < 1) return []

    const lowerQuery = query.toLowerCase()
    const results = searchData.filter((item) => {
      let score = 0
      if (item.title.toLowerCase().includes(lowerQuery)) score += 10
      if (item.description?.toLowerCase().includes(lowerQuery)) score += 5
      if (item.content?.toLowerCase().includes(lowerQuery)) score += 3
      if (item.tags?.some((tag) => tag.toLowerCase().includes(lowerQuery)))
        score += 4
      return score > 0
    })

    // Sort by relevance
    results.sort((a, b) => {
      const aTitle = a.title.toLowerCase().includes(lowerQuery) ? 10 : 0
      const bTitle = b.title.toLowerCase().includes(lowerQuery) ? 10 : 0
      const aDesc = a.description?.toLowerCase().includes(lowerQuery) ? 5 : 0
      const bDesc = b.description?.toLowerCase().includes(lowerQuery) ? 5 : 0
      return bTitle + bDesc - (aTitle + aDesc)
    })

    return results.slice(0, 10)
  }

  // 渲染搜索历史
  function renderSearchHistory() {
    const container = document.getElementById('search-results')
    if (!container) return

    const history = getSearchHistory()
    if (history.length === 0) {
      container.innerHTML = `
        <div class="search-hint px-3 py-8 text-center text-sm text-stone-500 dark:text-stone-400">
          输入关键词开始搜索
        </div>
      `
      return
    }

    container.innerHTML = `
      <div class="px-3 py-2">
        <div class="mb-2 flex items-center justify-between">
          <span class="text-xs font-medium text-stone-400 dark:text-stone-500">搜索历史</span>
          <button id="clear-history-btn" class="text-xs text-stone-400 hover:text-stone-600 dark:text-stone-500 dark:hover:text-stone-300">
            清除
          </button>
        </div>
        <div class="flex flex-wrap gap-2">
          ${history
            .map(
              (item) => `
            <button class="history-item rounded-full bg-stone-100 px-3 py-1 text-xs text-stone-600 transition-colors hover:bg-stone-200 dark:bg-stone-800 dark:text-stone-400 dark:hover:bg-stone-700">
              ${item}
            </button>
          `,
            )
            .join('')}
        </div>
      </div>
    `

    // 绑定清除按钮
    document
      .getElementById('clear-history-btn')
      ?.addEventListener('click', () => {
        clearSearchHistory()
        renderSearchHistory()
      })

    // 绑定历史项点击
    container.querySelectorAll('.history-item').forEach((item) => {
      item.addEventListener('click', () => {
        const input = document.getElementById(
          'search-input',
        ) as HTMLInputElement
        if (input) {
          input.value = item.textContent?.trim() || ''
          input.dispatchEvent(new Event('input'))
        }
      })
    })
  }

  function renderResults(results: SearchItem[], query: string) {
    const container = document.getElementById('search-results')
    if (!container) return

    if (results.length === 0 && query) {
      container.innerHTML = `
        <div class="px-3 py-8 text-center text-sm text-stone-500 dark:text-stone-400">
          没有找到 "<span class="font-medium">${query}</span>" 的相关结果
        </div>
      `
      return
    }

    if (results.length === 0) {
      renderSearchHistory()
      return
    }

    container.innerHTML = results
      .map(
        (item, index) => `
        <a
          href="${item.url}"
          class="search-result-item block rounded-lg px-3 py-2.5 transition-colors hover:bg-stone-100 dark:hover:bg-stone-800 ${index === selectedIndex ? 'bg-stone-100 dark:bg-stone-800' : ''}"
          data-index="${index}"
        >
          <div class="flex items-center gap-2">
            <span class="shrink-0 rounded px-1.5 py-0.5 text-xs ${item.type === 'post' ? 'bg-blue-100 text-blue-700 dark:bg-blue-900/50 dark:text-blue-300' : 'bg-green-100 text-green-700 dark:bg-green-900/50 dark:text-green-300'}">
              ${item.type === 'post' ? '文章' : '碎碎念'}
            </span>
            <span class="flex-1 truncate text-sm font-medium text-stone-800 dark:text-stone-200">
              ${highlightText(item.title, query)}
            </span>
          </div>
          ${item.description ? `<p class="mt-1 truncate text-xs text-stone-500 dark:text-stone-400">${highlightText(item.description, query)}</p>` : ''}
        </a>
      `,
      )
      .join('')

    selectedIndex = -1
  }

  function updateSelection(newIndex: number) {
    const items = document.querySelectorAll('.search-result-item')
    if (items.length === 0) return

    // Clamp index
    if (newIndex < 0) newIndex = items.length - 1
    if (newIndex >= items.length) newIndex = 0

    // Update classes
    items.forEach((item, i) => {
      if (i === newIndex) {
        item.classList.add('bg-stone-100', 'dark:bg-stone-800')
      } else {
        item.classList.remove('bg-stone-100', 'dark:bg-stone-800')
      }
    })

    selectedIndex = newIndex

    // Scroll into view
    const selectedItem = items[newIndex] as HTMLElement
    selectedItem?.scrollIntoView({ block: 'nearest' })
  }

  function setupSearch() {
    const modal = document.getElementById('search-modal')
    const toggle = document.getElementById('search-toggle')
    const input = document.getElementById('search-input') as HTMLInputElement
    const container = modal?.querySelector('.search-container')

    if (!modal || !toggle || !input || !container) return

    const openModal = async () => {
      await loadSearchData()
      modal.classList.remove('hidden')
      modal.classList.add('flex')
      requestAnimationFrame(() => {
        container.classList.remove('opacity-0', 'scale-95', 'translate-y-4')
        container.classList.add('opacity-100', 'scale-100', 'translate-y-0')
        input.focus()
      })
    }

    const closeModal = () => {
      container.classList.add('opacity-0', 'scale-95', 'translate-y-4')
      container.classList.remove('opacity-100', 'scale-100', 'translate-y-0')

      setTimeout(() => {
        modal.classList.add('hidden')
        modal.classList.remove('flex')
        input.value = ''
        renderSearchHistory()
        selectedIndex = -1
      }, 200)
    }

    // Toggle button click
    toggle.addEventListener('click', openModal)

    // Click outside to close
    modal.addEventListener('click', (e) => {
      if (e.target === modal) {
        closeModal()
      }
    })

    // Keyboard shortcuts
    document.addEventListener('keydown', (e) => {
      // Ctrl/Cmd + K to open
      if ((e.ctrlKey || e.metaKey) && e.key === 'k') {
        e.preventDefault()
        if (modal.classList.contains('hidden')) {
          openModal()
        } else {
          closeModal()
        }
      }

      // ESC to close
      if (e.key === 'Escape' && !modal.classList.contains('hidden')) {
        closeModal()
      }

      // Arrow keys and Enter when modal is open
      if (!modal.classList.contains('hidden')) {
        const items = document.querySelectorAll('.search-result-item')

        if (e.key === 'ArrowDown') {
          e.preventDefault()
          updateSelection(selectedIndex + 1)
        } else if (e.key === 'ArrowUp') {
          e.preventDefault()
          updateSelection(selectedIndex - 1)
        } else if (e.key === 'Enter' && selectedIndex >= 0) {
          e.preventDefault()
          const selectedItem = items[selectedIndex] as HTMLAnchorElement
          if (selectedItem) {
            // 保存到搜索历史
            const query = input.value.trim()
            saveSearchHistory(query)
            window.location.href = selectedItem.href
          }
        }
      }
    })

    // Search input
    let debounceTimer: ReturnType<typeof setTimeout>
    input.addEventListener('input', () => {
      clearTimeout(debounceTimer)
      debounceTimer = setTimeout(() => {
        const query = input.value.trim()
        const results = search(query)
        renderResults(results, query)
      }, 150)
    })

    // 点击搜索结果时保存历史
    const resultsContainer = document.getElementById('search-results')
    resultsContainer?.addEventListener('click', (e) => {
      const target = e.target as HTMLElement
      const link = target.closest('.search-result-item')
      if (link) {
        const query = input.value.trim()
        saveSearchHistory(query)
      }
    })
  }

  function setupMoreMenu() {
    const moreBtn = document.getElementById('more-btn')
    const moreDropdown = document.getElementById('more-dropdown')

    if (!moreBtn || !moreDropdown) return

    let isOpen = false

    const openDropdown = () => {
      isOpen = true
      moreDropdown.classList.remove('hidden')
      moreBtn.setAttribute('aria-expanded', 'true')
    }

    const closeDropdown = () => {
      isOpen = false
      moreDropdown.classList.add('hidden')
      moreBtn.setAttribute('aria-expanded', 'false')
    }

    moreBtn.addEventListener('click', (e) => {
      e.stopPropagation()
      if (isOpen) {
        closeDropdown()
      } else {
        openDropdown()
      }
    })

    // 点击外部关闭
    document.addEventListener('click', (e) => {
      if (isOpen && !moreDropdown.contains(e.target as Node)) {
        closeDropdown()
      }
    })

    // ESC 关闭
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && isOpen) {
        closeDropdown()
      }
    })
  }

  // Initialize
  setupSearch()
  setupMoreMenu()

  // Re-run after Astro page transitions
  document.addEventListener('astro:after-swap', () => {
    setupSearch()
    setupMoreMenu()
  })
</script>

---
export const prerender = true;

import Container from "@components/Container.astro";
import { THOUGHTS } from "@consts";
import PageLayout from "@layouts/PageLayout.astro";
---

<PageLayout title={`发布 ${THOUGHTS.TITLE}`} description="发布新的碎碎念">
  <Container>
    <div class="space-y-8">
      <div class="animate">
        <h1
          class="mb-2 text-3xl font-semibold text-stone-900 dark:text-stone-100"
        >
          发布碎碎念
        </h1>
        <p class="text-stone-600 dark:text-stone-400">
          记录此刻的想法，支持 Markdown 格式
        </p>
      </div>

      <!-- 认证区域 -->
      <div id="auth-section" class="animate">
        <label
          class="mb-2 block text-sm font-medium text-stone-700 dark:text-stone-300"
        >
          API Token
        </label>
        <div class="flex gap-2">
          <input
            type="password"
            id="api-token"
            placeholder="输入你的 API Token"
            class="flex-1 rounded-lg border border-stone-300 bg-white px-4 py-2 text-stone-900 placeholder-stone-400 focus:border-stone-500 focus:ring-2 focus:ring-stone-500/20 focus:outline-none dark:border-stone-700 dark:bg-stone-800 dark:text-stone-100 dark:placeholder-stone-500"
          />
          <button
            id="save-token-btn"
            class="rounded-lg bg-stone-200 px-4 py-2 text-sm font-medium text-stone-700 transition-colors hover:bg-stone-300 dark:bg-stone-700 dark:text-stone-300 dark:hover:bg-stone-600"
          >
            保存
          </button>
        </div>
        <p class="mt-1 text-xs text-stone-500 dark:text-stone-400">
          Token 将保存在本地，不会上传到服务器
        </p>
      </div>

      <!-- 编辑器区域 -->
      <div class="animate grid gap-6 lg:grid-cols-2">
        <!-- 输入区 -->
        <div class="space-y-4">
          <div>
            <label
              class="mb-2 block text-sm font-medium text-stone-700 dark:text-stone-300"
            >
              内容 <span class="text-rose-500">*</span>
            </label>
            <textarea
              id="content"
              rows="8"
              placeholder="写下你此刻的想法..."
              class="w-full resize-none rounded-lg border border-stone-300 bg-white px-4 py-3 text-stone-900 placeholder-stone-400 focus:border-stone-500 focus:ring-2 focus:ring-stone-500/20 focus:outline-none dark:border-stone-700 dark:bg-stone-800 dark:text-stone-100 dark:placeholder-stone-500"
            ></textarea>
            <div
              class="mt-1 flex justify-between text-xs text-stone-500 dark:text-stone-400"
            >
              <span>支持 Markdown 语法</span>
              <span id="char-count">0 字</span>
            </div>
          </div>

          <div>
            <label
              class="mb-2 block text-sm font-medium text-stone-700 dark:text-stone-300"
            >
              标签
            </label>
            <div class="flex flex-wrap gap-2" id="tags-container">
              <button
                type="button"
                class="tag-btn rounded-full border border-stone-900 bg-stone-900 px-3 py-1 text-xs font-medium text-white transition-all dark:border-stone-100 dark:bg-stone-100 dark:text-stone-900"
                data-tag="日常">日常</button
              >
              <button
                type="button"
                class="tag-btn rounded-full border border-stone-300 px-3 py-1 text-xs font-medium text-stone-600 transition-all hover:border-stone-400 hover:bg-stone-100 dark:border-stone-600 dark:text-stone-400 dark:hover:border-stone-500 dark:hover:bg-stone-700"
                data-tag="技术">技术</button
              >
              <button
                type="button"
                class="tag-btn rounded-full border border-stone-300 px-3 py-1 text-xs font-medium text-stone-600 transition-all hover:border-stone-400 hover:bg-stone-100 dark:border-stone-600 dark:text-stone-400 dark:hover:border-stone-500 dark:hover:bg-stone-700"
                data-tag="心情">心情</button
              >
              <button
                type="button"
                class="tag-btn rounded-full border border-stone-300 px-3 py-1 text-xs font-medium text-stone-600 transition-all hover:border-stone-400 hover:bg-stone-100 dark:border-stone-600 dark:text-stone-400 dark:hover:border-stone-500 dark:hover:bg-stone-700"
                data-tag="想法">想法</button
              >
              <button
                type="button"
                class="tag-btn rounded-full border border-stone-300 px-3 py-1 text-xs font-medium text-stone-600 transition-all hover:border-stone-400 hover:bg-stone-100 dark:border-stone-600 dark:text-stone-400 dark:hover:border-stone-500 dark:hover:bg-stone-700"
                data-tag="音乐">音乐</button
              >
              <button
                type="button"
                class="tag-btn rounded-full border border-stone-300 px-3 py-1 text-xs font-medium text-stone-600 transition-all hover:border-stone-400 hover:bg-stone-100 dark:border-stone-600 dark:text-stone-400 dark:hover:border-stone-500 dark:hover:bg-stone-700"
                data-tag="阅读">阅读</button
              >
            </div>
            <input
              type="text"
              id="custom-tag"
              placeholder="自定义标签，按回车添加"
              class="mt-2 w-full rounded-lg border border-stone-300 bg-white px-4 py-2 text-sm text-stone-900 placeholder-stone-400 focus:border-stone-500 focus:ring-2 focus:ring-stone-500/20 focus:outline-none dark:border-stone-700 dark:bg-stone-800 dark:text-stone-100 dark:placeholder-stone-500"
            />
          </div>

          <div>
            <label
              class="mb-2 block text-sm font-medium text-stone-700 dark:text-stone-300"
            >
              文件名标识 <span class="text-stone-400">(可选)</span>
            </label>
            <input
              type="text"
              id="name"
              placeholder="留空则自动生成"
              class="w-full rounded-lg border border-stone-300 bg-white px-4 py-2 text-stone-900 placeholder-stone-400 focus:border-stone-500 focus:ring-2 focus:ring-stone-500/20 focus:outline-none dark:border-stone-700 dark:bg-stone-800 dark:text-stone-100 dark:placeholder-stone-500"
            />
          </div>

          <button
            id="submit-btn"
            class="w-full rounded-lg bg-stone-900 px-6 py-3 font-medium text-white transition-all hover:bg-stone-800 disabled:cursor-not-allowed disabled:opacity-50 dark:bg-stone-100 dark:text-stone-900 dark:hover:bg-stone-200"
          >
            <span id="submit-text">发布碎碎念</span>
            <span id="submit-loading" class="hidden">
              <svg class="inline h-5 w-5 animate-spin" viewBox="0 0 24 24">
                <circle
                  class="opacity-25"
                  cx="12"
                  cy="12"
                  r="10"
                  stroke="currentColor"
                  stroke-width="4"
                  fill="none"></circle>
                <path
                  class="opacity-75"
                  fill="currentColor"
                  d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"
                ></path>
              </svg>
              发布中...
            </span>
          </button>
        </div>

        <!-- 预览区 -->
        <div class="space-y-4">
          <div class="flex items-center justify-between">
            <label
              class="text-sm font-medium text-stone-700 dark:text-stone-300"
            >
              预览
            </label>
            <span class="text-xs text-stone-500 dark:text-stone-400"
              >实时预览效果</span
            >
          </div>
          <div
            class="min-h-[200px] rounded-lg border border-stone-200 bg-stone-50 p-4 dark:border-stone-700 dark:bg-stone-800/50"
          >
            <div
              class="flex items-center gap-2 py-1 text-xs font-semibold opacity-75"
            >
              <div class="h-1.5 w-1.5 rounded-full bg-rose-300"></div>
              <span class="text-rose-500">
                刚刚 · 周<span id="preview-weekday">?</span>
              </span>
              <span
                id="preview-tags"
                class="text-stone-400 dark:text-stone-600"
              >
                #日常
              </span>
            </div>
            <div
              class="ml-0.5 border-l-2 border-stone-200 py-4 pl-6 dark:border-stone-700"
            >
              <article
                id="preview-content"
                class="prose prose-sm prose-stone dark:prose-invert"
              >
                <p class="text-stone-400 italic">在左侧输入内容开始预览...</p>
              </article>
            </div>
          </div>
        </div>
      </div>

      <!-- 结果展示 -->
      <div id="result-section" class="animate hidden">
        <div
          id="result-success"
          class="hidden rounded-lg border border-green-200 bg-green-50 p-4 dark:border-green-800 dark:bg-green-900/20"
        >
          <div class="flex items-start gap-3">
            <span class="text-2xl">🎉</span>
            <div class="flex-1">
              <h3 class="font-semibold text-green-800 dark:text-green-300">
                发布成功！
              </h3>
              <p
                id="result-message"
                class="mt-1 text-sm text-green-700 dark:text-green-400"
              >
              </p>
              <div id="result-links" class="mt-3 flex flex-wrap gap-2"></div>
            </div>
          </div>
        </div>
        <div
          id="result-error"
          class="hidden rounded-lg border border-rose-200 bg-rose-50 p-4 dark:border-rose-800 dark:bg-rose-900/20"
        >
          <div class="flex items-start gap-3">
            <span class="text-2xl">😢</span>
            <div>
              <h3 class="font-semibold text-rose-800 dark:text-rose-300">
                发布失败
              </h3>
              <p
                id="error-message"
                class="mt-1 text-sm text-rose-700 dark:text-rose-400"
              >
              </p>
            </div>
          </div>
        </div>
      </div>

      <!-- 帮助信息 -->
      <div
        class="animate rounded-lg border border-stone-200 bg-stone-50 p-4 dark:border-stone-700 dark:bg-stone-800/50"
      >
        <h3 class="mb-2 font-medium text-stone-900 dark:text-stone-100">
          💡 使用说明
        </h3>
        <ul class="space-y-1 text-sm text-stone-600 dark:text-stone-400">
          <li>• 内容支持 Markdown 格式，可以插入图片链接</li>
          <li>• 发布后会自动创建 GitHub Commit</li>
          <li>• 网站会在几分钟内自动重新部署更新</li>
          <li>• API Token 仅保存在浏览器本地，请妥善保管</li>
        </ul>
      </div>
    </div>
  </Container>
</PageLayout>

<script>
  // 获取当前星期几
  function getWeekday(): string {
    const weekdays = ['日', '一', '二', '三', '四', '五', '六']
    return weekdays[new Date().getDay()]
  }

  // 简单的 Markdown 解析（仅用于预览）
  function parseMarkdown(text: string): string {
    if (!text.trim())
      return '<p class="text-stone-400 italic">在左侧输入内容开始预览...</p>'

    return (
      text
        // 图片
        .replace(
          /!\[([^\]]*)\]\(([^)]+)\)/g,
          '<img src="$2" alt="$1" class="max-w-60 h-auto rounded" />',
        )
        // 链接
        .replace(
          /\[([^\]]+)\]\(([^)]+)\)/g,
          '<a href="$2" class="text-stone-600 underline hover:text-stone-900 dark:text-stone-400 dark:hover:text-stone-200" target="_blank">$1</a>',
        )
        // 粗体
        .replace(/\*\*([^*]+)\*\*/g, '<strong>$1</strong>')
        // 斜体
        .replace(/\*([^*]+)\*/g, '<em>$1</em>')
        // 标记
        .replace(
          /<mark>([^<]+)<\/mark>/g,
          '<mark class="bg-yellow-200 dark:bg-yellow-800 px-1 rounded">$1</mark>',
        )
        // 行内代码
        .replace(
          /`([^`]+)`/g,
          '<code class="bg-stone-200 dark:bg-stone-700 px-1 rounded text-sm">$1</code>',
        )
        // 段落
        .split('\n\n')
        .map((p) => `<p class="my-2">${p.replace(/\n/g, '<br>')}</p>`)
        .join('')
    )
  }

  // 初始化
  document.addEventListener('DOMContentLoaded', () => {
    const contentEl = document.getElementById('content') as HTMLTextAreaElement
    const nameEl = document.getElementById('name') as HTMLInputElement
    const tokenEl = document.getElementById('api-token') as HTMLInputElement
    const customTagEl = document.getElementById(
      'custom-tag',
    ) as HTMLInputElement
    const tagsContainer = document.getElementById('tags-container')!
    const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement
    const charCountEl = document.getElementById('char-count')!
    const previewContentEl = document.getElementById('preview-content')!
    const previewTagsEl = document.getElementById('preview-tags')!
    const previewWeekdayEl = document.getElementById('preview-weekday')!
    const resultSection = document.getElementById('result-section')!
    const resultSuccess = document.getElementById('result-success')!
    const resultError = document.getElementById('result-error')!
    const resultMessage = document.getElementById('result-message')!
    const resultLinks = document.getElementById('result-links')!
    const errorMessage = document.getElementById('error-message')!

    // 设置预览星期
    previewWeekdayEl.textContent = getWeekday()

    // 从 localStorage 加载 token
    const savedToken = localStorage.getItem('thought_api_token')
    if (savedToken) {
      tokenEl.value = savedToken
    }

    // 保存 token
    document.getElementById('save-token-btn')?.addEventListener('click', () => {
      localStorage.setItem('thought_api_token', tokenEl.value)
      alert('Token 已保存！')
    })

    // 获取选中的标签
    function getSelectedTags(): string[] {
      const tags: string[] = []
      tagsContainer.querySelectorAll('.tag-btn').forEach((btn) => {
        // 检查是否为 active 状态（通过背景色判断）
        if (btn.className.includes('bg-stone-900')) {
          tags.push((btn as HTMLElement).dataset.tag!)
        }
      })
      return tags
    }

    // 更新预览标签
    function updatePreviewTags() {
      const tags = getSelectedTags()
      previewTagsEl.textContent = tags.map((t) => `#${t}`).join(' ') || '#日常'
    }

    const activeClass =
      'tag-btn rounded-full border border-stone-900 bg-stone-900 px-3 py-1 text-xs font-medium text-white transition-all dark:border-stone-100 dark:bg-stone-100 dark:text-stone-900'
    const inactiveClass =
      'tag-btn rounded-full border border-stone-300 px-3 py-1 text-xs font-medium text-stone-600 transition-all hover:border-stone-400 hover:bg-stone-100 dark:border-stone-600 dark:text-stone-400 dark:hover:border-stone-500 dark:hover:bg-stone-700'

    // 标签点击
    tagsContainer.addEventListener('click', (e) => {
      const btn = (e.target as HTMLElement).closest('.tag-btn') as HTMLElement
      if (btn) {
        const isActive = btn.className.includes('bg-stone-900')
        btn.className = isActive ? inactiveClass : activeClass
        updatePreviewTags()
      }
    })

    // 自定义标签
    customTagEl.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' && customTagEl.value.trim()) {
        e.preventDefault()
        const tag = customTagEl.value.trim()

        // 检查是否已存在
        const existing = tagsContainer.querySelector(`[data-tag="${tag}"]`)
        if (existing) {
          // 切换为 active 样式
          existing.className =
            'tag-btn rounded-full border border-stone-900 bg-stone-900 px-3 py-1 text-xs font-medium text-white transition-all dark:border-stone-100 dark:bg-stone-100 dark:text-stone-900'
        } else {
          const btn = document.createElement('button')
          btn.type = 'button'
          btn.className =
            'tag-btn rounded-full border border-stone-900 bg-stone-900 px-3 py-1 text-xs font-medium text-white transition-all dark:border-stone-100 dark:bg-stone-100 dark:text-stone-900'
          btn.dataset.tag = tag
          btn.textContent = tag
          tagsContainer.appendChild(btn)
        }

        customTagEl.value = ''
        updatePreviewTags()
      }
    })

    // 内容输入 - 更新字数和预览
    contentEl.addEventListener('input', () => {
      const text = contentEl.value
      charCountEl.textContent = `${text.length} 字`
      previewContentEl.innerHTML = parseMarkdown(text)
    })

    // 提交
    submitBtn.addEventListener('click', async () => {
      const content = contentEl.value.trim()
      const token = tokenEl.value.trim()
      const name = nameEl.value.trim()
      const tags = getSelectedTags()

      if (!token) {
        alert('请先输入 API Token')
        tokenEl.focus()
        return
      }

      if (!content) {
        alert('请输入内容')
        contentEl.focus()
        return
      }

      // 显示加载状态
      submitBtn.disabled = true
      document.getElementById('submit-text')!.classList.add('hidden')
      document.getElementById('submit-loading')!.classList.remove('hidden')
      resultSection.classList.add('hidden')

      try {
        const response = await fetch('/api/add-thought', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            Authorization: `Bearer ${token}`,
          },
          body: JSON.stringify({
            content,
            tags: tags.length > 0 ? tags : ['日常'],
            name: name || undefined,
          }),
        })

        const data = await response.json()

        resultSection.classList.remove('hidden')

        if (data.success) {
          resultSuccess.classList.remove('hidden')
          resultError.classList.add('hidden')
          resultMessage.textContent = `碎碎念已成功创建！文件: ${data.data.filename}`

          // 添加链接
          resultLinks.innerHTML = `
            <a href="${data.data.github.commitUrl}" target="_blank" class="inline-flex items-center gap-1 rounded bg-green-100 px-3 py-1 text-sm text-green-700 hover:bg-green-200 dark:bg-green-800 dark:text-green-300 dark:hover:bg-green-700">
              <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
              查看 Commit
            </a>
            <a href="${data.data.github.fileUrl}" target="_blank" class="inline-flex items-center gap-1 rounded bg-stone-100 px-3 py-1 text-sm text-stone-700 hover:bg-stone-200 dark:bg-stone-700 dark:text-stone-300 dark:hover:bg-stone-600">
              查看文件
            </a>
            <a href="/thoughts" class="inline-flex items-center gap-1 rounded bg-stone-100 px-3 py-1 text-sm text-stone-700 hover:bg-stone-200 dark:bg-stone-700 dark:text-stone-300 dark:hover:bg-stone-600">
              碎碎念页面
            </a>
          `

          // 清空表单
          contentEl.value = ''
          nameEl.value = ''
          charCountEl.textContent = '0 字'
          previewContentEl.innerHTML =
            '<p class="text-stone-400 italic">在左侧输入内容开始预览...</p>'
        } else {
          resultSuccess.classList.add('hidden')
          resultError.classList.remove('hidden')
          errorMessage.textContent = data.message || '未知错误'
        }
      } catch (error) {
        resultSection.classList.remove('hidden')
        resultSuccess.classList.add('hidden')
        resultError.classList.remove('hidden')
        errorMessage.textContent =
          error instanceof Error ? error.message : '网络错误'
      } finally {
        submitBtn.disabled = false
        document.getElementById('submit-text')!.classList.remove('hidden')
        document.getElementById('submit-loading')!.classList.add('hidden')
      }
    })
  })

  // Astro View Transitions 支持
  document.addEventListener('astro:page-load', () => {
    // 重新初始化（如果需要）
  })
</script>

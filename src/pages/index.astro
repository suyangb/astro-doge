---
import { type CollectionEntry, getCollection } from "astro:content";
import Container from "@components/Container.astro";
import Link from "@components/Link.astro";
import { HOME, SITE } from "@consts";
import PageLayout from "@layouts/PageLayout.astro";
import { formatDate, readingTime, timeAgo } from "@lib/utils";

const posts = (await getCollection("posts"))
	.filter((post: CollectionEntry<"posts">) => !post.data.draft)
	.sort(
		(a: CollectionEntry<"posts">, b: CollectionEntry<"posts">) =>
			b.data.date.valueOf() - a.data.date.valueOf(),
	);

const thoughts = (await getCollection("thoughts"))
	.filter((thought: CollectionEntry<"thoughts">) => !thought.data.draft)
	.sort(
		(a: CollectionEntry<"thoughts">, b: CollectionEntry<"thoughts">) =>
			b.data.date.valueOf() - a.data.date.valueOf(),
	);
---

<PageLayout title={HOME.TITLE} description={HOME.DESCRIPTION}>
  <Container>
    <div class="space-y-10">
      <!-- Hero -->
      <section class="animate">
        <div class="space-y-3 sm:space-y-4">
          <h1
            class="text-2xl font-bold text-stone-900 sm:text-3xl dark:text-stone-100"
          >
            {SITE.NAME}
          </h1>
          <p class="text-sm text-stone-600 sm:text-base dark:text-stone-400">
            {SITE.DESCRIPTION}
          </p>
          <p class="text-sm text-stone-500 sm:text-base dark:text-stone-400">
            一个基于 <Link href="https://astro.build" external underline={true}>Astro</Link> 和 <Link href="https://tailwindcss.com" external underline={true}>Tailwind CSS</Link> 构建的博客主题，简洁、快速、可定制。
          </p>
        </div>
      </section>

      <hr class="border-stone-200 dark:border-stone-800" />

      <section class="animate space-y-6">
        <div class="flex flex-wrap items-center justify-between gap-y-2">
          <h2 class="font-semibold text-stone-900 dark:text-stone-100">
            最近文章
          </h2>
          <Link href="/posts"> 查看全部 →</Link>
        </div>
        <ul class="flex flex-col space-y-6">
          {
            posts.slice(0, SITE.NUM_POSTS_ON_HOMEPAGE).map((post) => (
              <li>
                <a
                  href={`/${post.data.slug || post.slug}`}
                  class="group -mx-3 block space-y-1.5 rounded-lg p-3 transition-colors duration-200 hover:bg-stone-100/50 dark:hover:bg-stone-800/50"
                >
                  <div class="flex flex-wrap items-baseline justify-between gap-4">
                    <h3 class="flex-1 font-semibold text-stone-800 transition-colors duration-300 group-hover:text-stone-950 dark:text-stone-200 dark:group-hover:text-stone-50">
                      {post.data.title}
                    </h3>
                    <span class="font-mono text-xs whitespace-nowrap text-stone-400 dark:text-stone-500">
                      {formatDate(post.data.date)} · {readingTime(post.body)}
                    </span>
                  </div>
                  {post.data.description && (
                    <p class="line-clamp-1 text-sm text-stone-500 dark:text-stone-400">
                      {post.data.description}
                    </p>
                  )}
                </a>
              </li>
            ))
          }
        </ul>
      </section>

      <hr class="border-stone-200 dark:border-stone-800" />

      <!-- 最近碎碎念 -->
      {
        thoughts.length > 0 && (
          <section class="animate space-y-6">
            <div class="flex flex-wrap items-center justify-between gap-y-2">
              <h2 class="font-semibold text-stone-900 dark:text-stone-100">
                最近动态
              </h2>
              <Link href="/thoughts"> 查看全部 →</Link>
            </div>
            <div class="space-y-4">
              {thoughts
                .slice(0, SITE.NUM_THOUGHTS_ON_HOMEPAGE)
                .map(async (thought, index) => {
                  const { Content } = await thought.render()
                  const thoughtId = thoughts.length - index
                  return (
                    <a
                      href={`/thoughts#${thoughtId}`}
                      class="group -mx-3 block rounded-lg p-3 transition-colors duration-200 hover:bg-stone-100/50 dark:hover:bg-stone-800/50"
                    >
                      <div class="flex items-center gap-2 text-xs">
                        <span class="rounded-full bg-gradient-to-r from-stone-200 to-stone-100 px-2 py-0.5 font-semibold text-stone-600 dark:from-stone-700 dark:to-stone-800 dark:text-stone-300">
                          #{thoughtId}
                        </span>
                        <span
                          class="time-ago text-stone-400 dark:text-stone-500"
                          data-timestamp={thought.data.date.getTime()}
                        >
                          {timeAgo(thought.data.date)}
                        </span>
                      </div>
                      <div class="home-thought-content mt-2 line-clamp-2 text-sm text-stone-600 dark:text-stone-300 [&_p]:my-0">
                        <Content />
                      </div>
                    </a>
                  )
                })}
            </div>
          </section>
        )
      }
    </div>
  </Container>
</PageLayout>

<script>
  import { setupTimeAgo } from '@lib/timeago-client'

  function init() {
    setupTimeAgo()
  }

  document.addEventListener('DOMContentLoaded', init)
  document.addEventListener('astro:after-swap', init)

  if (document.readyState === 'complete') {
    init()
  }
</script>

<style>
  /* 主页碎碎念图片样式 */
  .home-thought-content :global(img) {
    max-width: 6rem;
    height: auto;
    border-radius: 0.375rem;
    margin: 0.5rem 0;
  }

  /* 主页碎碎念链接样式 */
  .home-thought-content :global(a) {
    color: inherit;
    text-decoration: underline;
    text-decoration-color: rgba(168, 162, 158, 0.5);
    text-underline-offset: 2px;
  }
</style>

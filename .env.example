# GitHub Personal Access Token
# 需要有 repo 权限来创建文件
# 创建地址: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 碎碎念 API Token
# 用于验证 API 请求，可以自己生成一个随机字符串
# 例如: openssl rand -hex 32
THOUGHT_API_TOKEN=your_secure_random_token_here

# ================
# 下面的是 Vercel 的 env 配置

# 存储博客评论的 GitHub 仓库
# 用仓库的 Issue 存储评论
GITHUB_REPO=dogxii/blog-comments
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 邮件推送配置
SMTP_HOST=smtp.exmail.qq.com
SMTP_PORT=465
SMTP_USER="Dogxi 的狗窝"
SMTP_PASS=your_email_password
NOTIFICATION_EMAIL=blog-comments@dogxi.me
# ================
